{
    # ACME contact — Let's Encrypt uses this for expiry/issue notices.
    email hello@vylexai.com
}

api.vylexai.com {
    encode zstd gzip

    # Hide framework fingerprinting; keep CORS here at the edge so the
    # Android app's same-origin-style behavior stays tight.
    header {
        -Server
        -X-Powered-By
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
    }

    reverse_proxy app:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
}
